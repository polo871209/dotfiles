#!/usr/bin/env bash
# pi-send — inject tmux pane output / a message into a pi instance in this
# tmux session. Prefers the tmux-bridge unix socket (same protocol as
# nvim/lua/pi.lua): one JSON line {"text": ...} per message. Falls back to
# pasting into the pi pane (bracketed paste + Enter) when no bridge listener
# is live. Multiple live pi panes -> fzf picker.
#
# Usage:
#   pi-send "message"                    # message only
#   pi-send -p <pane_id> "message"       # capture last 100 lines of pane + message
#   echo "..." | pi-send "message"       # use stdin (e.g. copy-mode selection) + message

set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "pi-send: not running inside a tmux session" >&2
  exit 1
fi

MESSAGE=""
LINES=100
PANE_ID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p) PANE_ID="$2"; shift 2 ;;
    *)  MESSAGE="$1"; shift ;;
  esac
done

# --- Find pi panes in this session ---
# pi's own process shows up as "node" in tmux (it's a node program), so we
# match on pi's own pane title (starts with π) instead of pane_current_command.

# NB: tmux passes \t through literally, so use a real tab in the format
PI_PANES=$(tmux list-panes -s -F $'#{pane_id}\t#{pane_title}\t#{window_name}' | awk -F'\t' '$2 ~ /^π/ {print $1 "\t" $3}')
if [[ -z "$PI_PANES" ]]; then
  echo "pi-send: no pi pane found in this tmux session" >&2
  exit 1
fi

# --- Socket discovery (mirrors nvim/lua/pi.lua) ---
# tmux-bridge.ts listens on <tmpdir>/pi-tmux-pane-<sanitized-pane-id>.sock,
# where tmpdir is Node's os.tmpdir() — on macOS the DARWIN_USER_TEMP_DIR,
# which may differ from our $TMPDIR, so probe several candidates.

socket_for_pane() {
  local pane_id="$1" safe name dir
  safe=$(printf '%s' "$pane_id" | tr -c 'a-zA-Z0-9_-' '_')
  name="pi-tmux-pane-${safe}.sock"
  local dirs=("${TMPDIR:-}" "$(getconf DARWIN_USER_TEMP_DIR 2>/dev/null || true)" /tmp)
  for dir in "${dirs[@]}"; do
    [[ -z "$dir" ]] && continue
    local sock="${dir%/}/$name"
    # -S: socket exists; empty-payload connect: a listener actually accepts
    # (macOS nc -z doesn't work with -U). Bridge ignores blank lines.
    if [[ -S "$sock" ]] && printf '' | nc -U -w 1 "$sock" 2>/dev/null; then
      printf '%s' "$sock"
      return 0
    fi
  done
  return 1
}

# Live bridges: "pane_id \t window_name \t sock" per line
LIVE=""
while IFS=$'\t' read -r pid wname; do
  if sock=$(socket_for_pane "$pid"); then
    LIVE+="${pid}\t${wname}\t${sock}\n"
  fi
done <<< "$PI_PANES"
LIVE=$(printf '%b' "$LIVE")

# --- Gather content ---

if [[ -n "$PANE_ID" ]]; then
  PANE_OUTPUT=$(tmux capture-pane -p -J -S "-$LINES" -t "$PANE_ID" 2>/dev/null | sed '/^[[:space:]]*$/d' || true)
elif [[ ! -t 0 ]]; then
  PANE_OUTPUT=$(cat)
else
  PANE_OUTPUT=""
fi

if [[ -n "$PANE_OUTPUT" ]]; then
  if [[ -n "$MESSAGE" ]]; then
    TEXT="terminal output:

$MESSAGE

\`\`\`
$PANE_OUTPUT
\`\`\`"
  else
    TEXT="terminal output:

\`\`\`
$PANE_OUTPUT
\`\`\`"
  fi
else
  if [[ -z "$MESSAGE" ]]; then
    echo "pi-send: nothing to send (no message, no pane, no stdin)" >&2
    exit 1
  fi
  TEXT="$MESSAGE"
fi

# --- Send via bridge socket when live ---

if [[ -n "$LIVE" ]]; then
  if [[ $(wc -l <<< "$LIVE") -gt 1 ]]; then
    CHOICE=$(fzf --height 40% --reverse --border --border-label ' send to which pi agent? ' \
      --with-nth 2 --delimiter '\t' <<< "$LIVE") || exit 1
  else
    CHOICE="$LIVE"
  fi
  SOCK=$(cut -f3 <<< "$CHOICE")
  # tmux-bridge drops lines >256KB
  if [[ ${#TEXT} -le 200000 ]]; then
    jq -nc --arg text "$TEXT" '{text: $text}' | nc -U -w 1 "$SOCK"
    tmux display-message "pi-send: sent to pi (bridge)"
    exit 0
  fi
fi

# --- Fallback: paste-buffer wraps in bracketed paste so multi-line text lands
# as one message instead of one Enter per line ---

TARGET=$(head -n1 <<< "$PI_PANES" | cut -f1)
printf '%s' "$TEXT" | tmux load-buffer -b pi-send -
tmux paste-buffer -p -b pi-send -d -t "$TARGET"
tmux send-keys -t "$TARGET" Enter
tmux display-message "pi-send: sent to pi (paste)"
