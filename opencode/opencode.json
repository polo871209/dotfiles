{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "py": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    }
  },
  // plugin order matters — keep the order
  "plugin": [
    "./plugins/system-prompt.ts",
    "@ex-machina/opencode-anthropic-auth"
  ],
  "lsp": {
    "cue": {
      "command": ["cue", "lsp", "serve"],
      "extensions": [".cue"]
    },
    "ty": {
      "command": ["uvx", "ty", "server"],
      "extensions": [".py"]
    }
  },
  "mcp": {
    "gcp": {
      "type": "local",
      "command": ["npx", "-y", "@google-cloud/observability-mcp"]
    }
  },
  "tools": {
    "gcp_*": false
  },
  "compaction": {
    "reserved": 50000
  },
  "permission": {
    "bash": {
      "kubectl apply *": "deny"
    },
    "external_directory": {
      "~/dotfiles/**": "allow",
      "~/app/**": "allow",
      "~/work/**": "allow",
      "~/vaults/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "agent": {
    "build": {
      "color": "#ea6962"
    },
    "plan": {
      "color": "#689d6a"
    }
  }
}
