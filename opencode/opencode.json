{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "py": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    }
  },
  "lsp": {
    "cue": {
      "command": ["cue", "lsp", "serve"],
      "extensions": [".cue"]
    },
    "ty": {
      "command": ["uvx", "ty", "server"],
      "extensions": [".py"]
    }
  },
  "mcp": {},
  "permission": {
    "external_directory": {
      "~/app/**": "allow",
      "~/work/**": "allow",
      "/tmp/**": "allow",
      "/private/**": "allow"
    }
  }
}
