#!/usr/bin/env zsh
# On a fresh herdr workspace, build the π/nvim/zsh layout and exec pi here.
# Sourced from .zshrc; any other shell returns early.
[[ "$HERDR_ENV" == 1 && -z "$HERDR_NO_BOOTSTRAP" ]] || return 0
command -v herdr >/dev/null 2>&1 || return 0
[[ -n "$HERDR_WORKSPACE_ID" && -n "$HERDR_TAB_ID" ]] || return 0

# Fresh workspace = one tab, one pane.
counts=$(herdr workspace get "$HERDR_WORKSPACE_ID" 2>/dev/null \
  | jq -r '.result.workspace | "\(.tab_count) \(.pane_count)"' 2>/dev/null)
[[ "$counts" == "1 1" ]] || return 0

herdr tab rename "$HERDR_TAB_ID" "π" >/dev/null 2>&1

# tab-autoname labels these tabs (nvim / zsh) once their shells run.
nvim_resp=$(herdr tab create --workspace "$HERDR_WORKSPACE_ID" \
  --no-focus --env HERDR_NO_BOOTSTRAP=1 2>/dev/null)
nvim_pane=$(printf '%s' "$nvim_resp" | jq -r '.result.root_pane.pane_id' 2>/dev/null)
nvim_tab=$(printf '%s' "$nvim_resp" | jq -r '.result.tab.tab_id' 2>/dev/null)
[[ -n "$nvim_pane" && "$nvim_pane" != null ]] && herdr pane run "$nvim_pane" "nvim" >/dev/null 2>&1

herdr tab create --workspace "$HERDR_WORKSPACE_ID" \
  --no-focus --env HERDR_NO_BOOTSTRAP=1 >/dev/null 2>&1

[[ -n "$nvim_tab" && "$nvim_tab" != null ]] && herdr tab focus "$nvim_tab" >/dev/null 2>&1

exec pi --continue
