#!/usr/bin/env zsh
# Fuzzy-pick a zoxide dir, then focus its workspace (matched by label) or create it.
set -euo pipefail

dir=$(zoxide query -l 2>/dev/null | fzf \
  --height 100% --reverse --border-label ' herdr ' --border --prompt '> ' \
  --preview 'eza -la --icons --group-directories-first {} 2>/dev/null || ls -la {}' \
  --color 'bg:#282828,bg+:#3c3836,fg:#89b4fa,fg+:#89b4fa' \
  --color 'hl:#fabd2f,hl+:#fabd2f,info:#83a598,marker:#8ec07c' \
  --color 'prompt:#d79921,spinner:#8ec07c,pointer:#fe8019,header:#928374' \
  --color 'border:#928374,label:#ebdbb2,query:#ebdbb2') || exit 0
[ -n "$dir" ] || exit 0

name=$(basename "$dir")
wid=$(herdr workspace list 2>/dev/null \
  | jq -r --arg n "$name" '.. | objects | select(.label? == $n and .workspace_id?) | .workspace_id' \
  | head -n1)

if [ -n "$wid" ]; then
  herdr workspace focus "$wid"
else
  # Fresh workspace; the .zshrc bootstrap builds the layout.
  herdr workspace create --cwd "$dir" --label "$name" --focus >/dev/null
fi
