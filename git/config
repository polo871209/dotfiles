[user]
	name = PoLo
	email = qazh0123@gmail.com
[init]
	defaultBranch = main
[core]
	autocrlf = input
	excludesFile = ~/.config/git/ignore
	editor = nvim
	filemode = false
	quotepath = false
[rerere]
	enabled = true
	autoupdate = true
[pull]
	rebase = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[diff]
	algorithm = histogram
[rebase]
	autoStash = true
	autoSquash = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[branch]
	sort = -committerdate
[column]
	ui = auto
